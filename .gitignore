# 敏感配置文件
.env
.env.*
*.env
wp-config.php
wp-config-sample.php

# 内部文档（不上传）
定制手册.md

# 密钥和证书
*.key
*.pem
*.p12
*.pfx
*.crt
*.cer
id_rsa*
id_dsa*
*.pub
credentials*
secrets*
*.secret

# 数据库文件
*.sql
*.sql.gz
*.sql.bz2
*.db
*.sqlite
*.sqlite3

# 备份文件
*.bak
*.backup
*.old
*.orig
*~

# 日志文件
*.log
logs/
error_log
debug.log

# IDE和编辑器
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# WordPress核心文件（通常不需要上传）
# wp-admin/
# wp-includes/
# index.php
# xmlrpc.php
# .htaccess

# 上传的文件（可能包含用户隐私数据）
# wp-content/uploads/
# wp-content/blogs.dir/

# 缓存文件
wp-content/cache/
wp-content/upgrade/
wp-content/backup-db/

# 插件（通常从官方安装）
# wp-content/plugins/*

# 编译和压缩文件
*.min.js
*.min.css
*.map

# 临时文件
tmp/
temp/
*.tmp
*.temp

# 压缩包（源代码管理不需要）
*.zip
*.tar
*.tar.gz
*.rar
*.7z

# Node.js（如果有前端构建）
node_modules/
npm-debug.log
yarn-error.log
package-lock.json
yarn.lock

# 其他敏感信息
.htpasswd
.ssh/
known_hosts
